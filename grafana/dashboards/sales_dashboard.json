{
  "id": null,
  "uid": "sales-monitoring",
  "title": "📊 Sales Data Monitoring",
  "description": "Real-time monitoring of CSV sales data via Prometheus",
  "tags": ["sales", "csv", "data-engineering"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "💰 Total Revenue (All Products)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(sales_total_revenue)",
          "legendFormat": "Total Revenue",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "📦 Total Units Sold",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(sales_total_units_sold)",
          "legendFormat": "Total Units",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "📈 Total Profit",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(sales_total_profit)",
          "legendFormat": "Total Profit",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "🔄 CSV Records Processed",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "orange", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "csv_records_processed_total",
          "legendFormat": "Records",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "💵 Revenue by Product",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000 },
              { "color": "red", "value": 50000 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (product) (sales_total_revenue)",
          "legendFormat": "{{product}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "🗺️ Revenue by Region",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (region) (sales_total_revenue)",
          "legendFormat": "{{region}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "gauge",
      "title": "📊 Profit Margin % by Product",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "green",  "value": 40 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sales_profit_margin_percent",
          "legendFormat": "{{product}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "📉 Revenue Over Time (per product)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "sum by (product) (sales_total_revenue)",
          "legendFormat": "{{product}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "table",
      "title": "🔍 Full Breakdown — Revenue / Units / Profit by Product & Region",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 28 },
      "options": {
        "sortBy": [{ "displayName": "Revenue", "desc": true }],
        "footer": { "show": true, "reducer": ["sum"], "fields": "" }
      },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Revenue" }, "properties": [{ "id": "unit", "value": "currencyUSD" }] },
          { "matcher": { "id": "byName", "options": "Profit"  }, "properties": [{ "id": "unit", "value": "currencyUSD" }] },
          { "matcher": { "id": "byName", "options": "Cost"    }, "properties": [{ "id": "unit", "value": "currencyUSD" }] }
        ]
      },
      "targets": [
        {
          "expr": "sum by (product, region, category) (sales_total_revenue)",
          "legendFormat": "{{product}} / {{region}}",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "sum by (product, region) (sales_total_units_sold)",
          "legendFormat": "",
          "refId": "B",
          "instant": true
        },
        {
          "expr": "sum by (product, region) (sales_total_profit)",
          "legendFormat": "",
          "refId": "C",
          "instant": true
        }
      ]
    }
  ]
}
